# AutoWebAgent - Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ── Application ───────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string-in-production
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ── MongoDB ───────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=autowebagent

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── DeepSeek LLM (Superadmin Global Key) ──────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Anti-Captcha (Superadmin Global Key) ──────────────────
ANTICAPTCHA_API_KEY=your-anticaptcha-key-here

# ── Webshare Proxy (Superadmin Global Credentials) ────────
WEBSHARE_PROXY_USERNAME=your-webshare-username
WEBSHARE_PROXY_PASSWORD=your-webshare-password
WEBSHARE_PROXY_HOST=p.webshare.io
WEBSHARE_PROXY_PORT=80

# ── Browser Automation ────────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=60000
MAX_CONCURRENT_SESSIONS_PER_USER=5

# ── Stealth ───────────────────────────────────────────────
STEALTH_MODE=ultra
FINGERPRINT_CONSISTENCY=true

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text

# ── Encryption Key (for stored API keys) ──────────────────
ENCRYPTION_KEY=autowebagent-fernet-key-must-be-32-bytes!

# ── Celery ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
